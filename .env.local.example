# Copy this file to .env.local and fill in real values. .env.local is
# git-ignored and must never be committed.

# Password required to sign in at /admin and upload a new CSV.
ADMIN_PASSWORD=change-me

# Random secret used to sign the admin session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_COOKIE_SECRET=change-me-too

# Optional: override where the local SQLite database file lives.
# Defaults to ./data/rkr.db. Ignored if TURSO_DATABASE_URL is set below.
# DATABASE_PATH=./data/rkr.db

# Optional: point at a remote Turso (libSQL) database instead of a local
# file — used in production. If unset, the app uses the local file above.
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=

# Optional: only needed in production (Vercel) to bypass the 4.5MB
# serverless request-body limit for large CSV uploads — the admin page
# uses a direct-to-storage upload instead of posting through our server
# when this is set. Auto-populated by Vercel once a Blob store is attached
# to the project; leave unset for local dev.
# BLOB_READ_WRITE_TOKEN=
